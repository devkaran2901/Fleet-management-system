# Copy this file to `.env` and adjust if your setup differs.
# `.env` is gitignored — never commit real secrets.

# Postgres. Host port 5433 matches database/docker-compose.yml.
DATABASE_URL="postgresql://postgres:postgrespassword@127.0.0.1:5433/fms_db?schema=public"

# Signing key for JWTs. Generate your own for anything but local dev.
JWT_SECRET="fms_super_secret_jwt_key_2026"

# Port the API listens on. The frontend expects 3000 (see frontend/src/services/api.ts).
PORT=3000

# Optional. Comma-separated origins allowed to call the API.
# Defaults to http://localhost:5173,http://localhost:4173 when unset.
# CORS_ORIGIN="http://localhost:5173"
