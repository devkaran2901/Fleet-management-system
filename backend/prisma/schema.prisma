// Prisma schema for the FMS RBAC foundation.
// Runtime queries go through the pg driver adapter (see PrismaService);
// migrations and `prisma db seed` use DATABASE_URL below.

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  firstName String
  lastName  String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  roles     UserRole[]

  costCenters      CostCenter[] @relation("CostCenterManager")
  delegationsFrom  Delegation[] @relation("DelegationFrom")
  delegationsTo    Delegation[] @relation("DelegationTo")

  @@map("users")
}

model Role {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  users        UserRole[]
  capabilities RoleCapability[]

  @@map("roles")
}

model UserRole {
  userId     String
  roleId     Int
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// ---------------------------------------------------------------------------
// P-01 Identity, RBAC & Org — org tree, capability x scope role builder
// ---------------------------------------------------------------------------

enum OrgNodeType {
  ORG
  REGION
  HUB
  DEPOT
  TEAM
}

model OrgNode {
  id       String      @id @default(uuid())
  name     String
  code     String      @unique
  type     OrgNodeType
  parentId String?
  parent      OrgNode?     @relation("OrgHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    OrgNode[]    @relation("OrgHierarchy")
  costCenters CostCenter[]

  @@index([parentId])
  @@map("org_nodes")
}

model Capability {
  key    String @id
  label  String
  group  String

  roles  RoleCapability[]

  @@map("capabilities")
}

// Cost centres hang off the org tree and carry the budget an org unit spends against.
model CostCenter {
  code            String   @id
  name            String
  department      String
  managerId       String?
  budgetAllocated Decimal  @default(0) @db.Decimal(14, 2)
  budgetUsed      Decimal  @default(0) @db.Decimal(14, 2)
  orgNodeId       String?
  createdAt       DateTime @default(now())

  manager User?    @relation("CostCenterManager", fields: [managerId], references: [id], onDelete: SetNull)
  orgNode OrgNode? @relation(fields: [orgNodeId], references: [id], onDelete: SetNull)

  @@index([orgNodeId])
  @@map("cost_centers")
}

// A time-boxed hand-off of one user's approval authority to another (e.g. leave cover).
model Delegation {
  id         String   @id @default(uuid())
  fromUserId String
  toUserId   String
  startDate  DateTime
  endDate    DateTime
  reason     String?
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  fromUser User @relation("DelegationFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("DelegationTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([fromUserId])
  @@index([toUserId])
  @@map("delegations")
}

enum CapabilityScope {
  GLOBAL
  REGION
  HUB
  SELF
}

model RoleCapability {
  roleId        Int
  capabilityKey String
  scope         CapabilityScope @default(HUB)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  capability Capability @relation(fields: [capabilityKey], references: [key], onDelete: Cascade)

  @@id([roleId, capabilityKey])
  @@map("role_capabilities")
}

// Pairs of capabilities that must never be held by one role (SoD).
model SegregationRule {
  id            Int    @id @default(autoincrement())
  capabilityA   String
  capabilityB   String
  message       String

  @@unique([capabilityA, capabilityB])
  @@map("segregation_rules")
}

// ---------------------------------------------------------------------------
// M-21 Compliance Suite — versioned, effective-dated rule packs
// ---------------------------------------------------------------------------

enum RulePackStatus {
  DRAFT
  ACTIVE
  RETIRED
}

model RulePack {
  id        String            @id @default(uuid())
  key       String            @unique
  name      String
  stateCode String
  versions  RulePackVersion[]

  @@map("rule_packs")
}

model RulePackVersion {
  id            String         @id @default(uuid())
  rulePackId    String
  version       Int
  status        RulePackStatus @default(DRAFT)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  rules         Json
  createdAt     DateTime       @default(now())

  rulePack RulePack @relation(fields: [rulePackId], references: [id], onDelete: Cascade)

  @@unique([rulePackId, version])
  @@map("rule_pack_versions")
}

// ---------------------------------------------------------------------------
// P-02 Approvals Engine
// ---------------------------------------------------------------------------

enum ApprovalStepType {
  APPROVAL
  THRESHOLD
  PARALLEL
  NOTIFY
}

model ApprovalFlow {
  id       String         @id @default(uuid())
  name     String
  entity   String
  isActive Boolean        @default(true)
  steps    ApprovalStep[]

  @@map("approval_flows")
}

model ApprovalStep {
  id              String           @id @default(uuid())
  flowId          String
  order           Int
  type            ApprovalStepType @default(APPROVAL)
  roleName        String
  thresholdAmount Decimal?         @db.Decimal(14, 2)
  slaHours        Int              @default(24)

  flow ApprovalFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@unique([flowId, order])
  @@map("approval_steps")
}

// ---------------------------------------------------------------------------
// P-03 Notifications
// ---------------------------------------------------------------------------

enum NotificationSeverity {
  INFO
  WARNING
  CRITICAL
}

model NotificationPolicy {
  id            String               @id @default(uuid())
  eventKey      String               @unique
  label         String
  severity      NotificationSeverity @default(INFO)
  channels      String[]
  audienceRole  String
  quietHours    Boolean              @default(false)
  digest        Boolean              @default(false)

  @@map("notification_policies")
}

// ---------------------------------------------------------------------------
// P-06 Integration & Import
// ---------------------------------------------------------------------------

enum ConnectorStatus {
  HEALTHY
  DEGRADED
  DOWN
  DISCONNECTED
}

model Connector {
  id         String          @id @default(uuid())
  key        String          @unique
  name       String
  category   String
  status     ConnectorStatus @default(DISCONNECTED)
  config     Json            @default("{}")
  lastSyncAt DateTime?

  @@map("connectors")
}

enum ImportStatus {
  MAPPING
  VALIDATED
  COMMITTED
  FAILED
}

model ImportJob {
  id          String       @id @default(uuid())
  entity      String
  fileName    String
  status      ImportStatus @default(MAPPING)
  totalRows   Int          @default(0)
  validRows   Int          @default(0)
  errorRows   Int          @default(0)
  mapping     Json         @default("{}")
  rows        Json         @default("[]")
  errors      Json         @default("[]")
  createdAt   DateTime     @default(now())
  committedAt DateTime?

  @@map("import_jobs")
}

// ---------------------------------------------------------------------------
// P-05 Audit — append-only, tamper-evident hash chain, lineage
// ---------------------------------------------------------------------------

model AuditEvent {
  seq        Int      @id @default(autoincrement())
  id         String   @unique @default(uuid())
  actorId    String?
  actorEmail String
  action     String
  entity     String
  entityId   String?
  payload    Json     @default("{}")
  // Lineage: the event this one was caused by (payment -> ... -> request).
  parentId   String?
  hash       String
  prevHash   String
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
  @@index([parentId])
  @@map("audit_events")
}

// ---------------------------------------------------------------------------
// Fleet Operations & Dispatcher Models
// ---------------------------------------------------------------------------

model Vehicle {
  id                    String   @id @default(uuid())
  photo                 String?
  vehicleNumber         String   @unique
  capacity              String
  currentLocation       String
  currentTripId         String?
  fuel                  Int
  status                String   // "Available", "In Transit", "Maintenance", "Blocked"
  complianceFASTag      Boolean  @default(true)
  compliancePM          Boolean  @default(true)
  complianceGPS         Boolean  @default(true)
  complianceInspection  Boolean  @default(true)
  complianceInsurance   Boolean  @default(true)
  complianceFitness     Boolean  @default(true)
  compliancePermit      Boolean  @default(true)
  utilization           Float    @default(0)
  category              String   @default("Owned") // "Owned" or "Vendor"
  vendorName            String?
  gpsDeviceStatus       String   @default("Online") // "Online", "Offline", "Tampered"
  lastPingAge           String   @default("2m ago")
  site                  String   @default("Delhi Hub")
  class                 String   @default("Container") // "Container", "Flatbed", "Open Body"
  alerts                Json     @default("[]") // Array of warning strings or objects
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("vehicles")
}

model Driver {
  id            String   @id @default(uuid())
  photo         String?
  name          String
  license       String
  licenseType   String
  dutyHours     Float    @default(0)
  restHours     Float    @default(0)
  safetyScore   Int      @default(90)
  currentTripId String?
  status        String   // "Available", "On Duty", "Off Duty", "Suspended"
  warnings      Json     @default("[]") // Array of warnings
  site          String   @default("Delhi Hub")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("drivers")
}

model TransportRequest {
  id                String   @id
  customer          String
  pickup            String
  destination       String
  vehicleType       String
  capacityRequired  String
  timeWindow        String
  priority          String   // "CRITICAL", "HIGH", "MEDIUM", "LOW"
  approvalStatus    String   // "APPROVED", "PENDING", "HOLD"
  tripType          String   // "FCL", "LCL", "Secondary"
  status            String   // "Unassigned", "Assigned", "Deferred", "Hold", "Merged", "Split"
  date              DateTime
  distance          Float
  eta               String
  ineligibleReasons Json     @default("{}") // Map of vehicle number/id to reason string
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("transport_requests")
}

model Trip {
  id             String    @id @default(uuid())
  tripId         String    @unique
  vehicleId      String?
  vehicleNumber  String?
  driverId       String?
  driverName     String?
  status         String    // "Scheduled", "In Transit", "Completed", "Cancelled"
  routeName      String
  pickup         String
  destination    String
  eta            String
  distance       Float
  startDateTime  DateTime?
  endDateTime    DateTime?
  cost           Float
  vendorName     String?
  documents      Json      @default("[]") // Array of { name, url, status }
  expenses       Json      @default("[]") // Array of { category, amount, status }
  fuelEntries    Json      @default("[]") // Array of { odo, liters, cost, station }
  gateEvents     Json      @default("[]") // Array of { event, timestamp }
  stateTimeline  Json      @default("[]") // Array of { state, timestamp }
  auditTrail     Json      @default("[]") // Array of { user, action, timestamp }
  timeline       Json      @default("[]") // Array of checkpoints with ETA, distance, and status
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("trips")
}

model GateQueueEntry {
  id              String    @id @default(uuid())
  vehicleNumber   String
  status          String    // "Expected", "Waiting", "Entered", "Exited", "Blocked"
  gatePassNumber  String
  eta             String
  enteredAt       DateTime?
  exitedAt        DateTime?
  detentionTimer  Int?      // Minutes
  checklistPhotos Json      @default("[]") // Array of images: load, seal, odo
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("gate_queue_entries")
}

model ExceptionAlert {
  id            String   @id @default(uuid())
  type          String   // "Overspeed", "SOS", "Breakdown", etc.
  vehicleNumber String
  driverName    String
  tripId        String?
  timestamp     DateTime @default(now())
  status        String   @default("Open") // "Open", "Acknowledged", "Resolved"
  severity      String   @default("WARNING") // "CRITICAL", "WARNING", "INFO"
  details       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("exception_alerts")
}

model Route {
  id           String   @id @default(uuid())
  code         String   @unique
  routeName    String
  origin       String
  destination  String
  distance     Float
  eta          String
  stops        Json     @default("[]") // Array of { name, geofence, seq }
  restrictions Json     @default("[]") // Array of { type, value, notes }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("routes")
}

// ---------------------------------------------------------------------------
// R-06 Workshop Manager Models
// ---------------------------------------------------------------------------

model JobCard {
  id             String   @id @default(uuid())
  jobCardNumber  String   @unique
  vehicleId      String?
  vehicleNumber  String
  status         String   @default("Draft") // Draft, Open, In Progress, Waiting Parts, QC, Road Test, Completed, Cost Posted
  priority       String   @default("MEDIUM") // CRITICAL, HIGH, MEDIUM, LOW
  bayId          String?
  bayName        String?
  mechanicId     String?
  mechanicName   String?
  complaint      String
  rootCause      String?
  odometer       Int      @default(0)
  hours          Float    @default(0)
  customer       String   @default("Internal Fleet")
  estimateTotal  Float    @default(0)
  actualCost     Float    @default(0)
  tasks          Json     @default("[]") // Array of { id, description, mechanic, stdHours, actualHours, status }
  parts          Json     @default("[]") // Array of { partNumber, name, qty, unitCost, totalCost, status }
  outsideWork    Json     @default("[]") // Array of { vendor, reason, estimate, status }
  qcChecklist    Json     @default("[]") // Array of { item, passed, notes }
  qcStatus       String   @default("Pending") // Pending, Approved, Rejected
  roadTestStatus String   @default("Not Required") // Not Required, Pending, Passed, Failed
  roadTestNotes  String?
  surveyorHeld   Boolean  @default(false)
  warrantyClaimed Boolean @default(false)
  auditTrail     Json     @default("[]")
  createdDate    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("job_cards")
}

model WorkshopBay {
  id               String   @id @default(uuid())
  name             String   @unique
  status           String   @default("Available") // Available, Busy, Waiting Parts, QC
  currentJobCardId String?
  currentVehicleId String?
  vehicleNumber    String?
  mechanicId       String?
  mechanicName     String?
  estimatedFinish  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("workshop_bays")
}

model WorkshopMechanic {
  id               String   @id @default(uuid())
  name             String
  skill            String   // Engine Specialist, Electrical, Hydraulics, General Tech, HVAC
  currentJobCardId String?
  assignedBay      String?
  status           String   @default("Available") // Available, Busy, On Break
  productivity     Int      @default(90) // percentage
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("workshop_mechanics")
}

model PmSchedule {
  id               String   @id @default(uuid())
  vehicleId        String?
  vehicleNumber    String
  currentOdometer  Int
  dueKm            Int
  dueDate          DateTime
  dueHours         Float    @default(0)
  triggerType      String   // KM, Hours, Time, Condition, Statutory
  status           String   @default("Normal") // Normal, Due, Overdue, Grace, Lock
  slotNegotiation  Json     @default("{}") // { proposedSlot, confirmedSlot, status, arbitrationLog }
  autoJobCardId    String?
  maintenanceGrace Boolean  @default(true)
  maintenanceLock  Boolean  @default(false)
  overrideApproved Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("pm_schedules")
}

model Estimate {
  id                String   @id @default(uuid())
  estimateNumber    String   @unique
  jobCardId         String
  vehicleNumber     String
  labourCost        Float    @default(0)
  partsCost         Float    @default(0)
  outsideWorkCost   Float    @default(0)
  tax               Float    @default(0)
  totalAmount       Float    @default(0)
  approvalStatus    String   @default("Draft") // Draft, PendingApproval, Approved, Rejected, RevisionRequired
  technicalApproval String   @default("Pending") // Pending, Approved, Rejected
  approvalTimeline  Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("estimates")
}

model PartsDemand {
  id                 String   @id @default(uuid())
  jobCardId          String
  vehicleNumber      String
  partNumber         String
  partName           String
  quantityRequired   Int
  quantityAvailable  Int
  reservationStatus  String   @default("Unreserved") // Unreserved, Reserved, Partial
  demandStatus       String   @default("Pending") // Pending, Requested, Fulfilled
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("parts_demands")
}

model OutsideWorkRequest {
  id               String   @id @default(uuid())
  jobCardId        String
  vehicleNumber    String
  vendor           String
  reason           String
  estimate         Float
  approvalStatus   String   @default("Pending") // Pending, Approved, Rejected
  completionStatus String   @default("In Progress") // In Progress, Completed, Cancelled
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("outside_work_requests")
}

// ---------------------------------------------------------------------------
// R-14 Finance Manager Models
// ---------------------------------------------------------------------------

model Budget {
  id               String   @id @default(uuid())
  budgetId         String   @unique
  costCenter       String
  department       String
  month            String
  budgetAmount     Float    @default(0)
  actualAmount     Float    @default(0)
  committedAmount  Float    @default(0)
  variance         Float    @default(0)
  percentage       Float    @default(0)
  status           String   @default("Normal") // Normal, Warning, Exception
  costCentersJson  Json     @default("[]")
  monthlyTrendJson Json     @default("[]")
  historyJson      Json     @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("budgets")
}

model VendorBill {
  id                   String   @id @default(uuid())
  billNumber           String   @unique
  vendor               String
  tripReference        String
  contract             String
  expectedAmount       Float    @default(0)
  billedAmount         Float    @default(0)
  tolerance            Float    @default(0)
  deviation            Float    @default(0)
  tax                  Float    @default(0)
  status               String   @default("Pending") // Pending, Verified, Approved, Rejected, Paid
  autoMatchStatus      String   @default("Matched") // Matched, Mismatch, ManualReview
  expectedVsBilledJson Json     @default("{}")
  toleranceCheckJson   Json     @default("{}")
  deviationQueueJson   Json     @default("{}")
  debitNotesJson       Json     @default("[]")
  taxSummaryJson       Json     @default("{}")
  rateComputationJson  Json     @default("{}")
  dieselEscalationJson Json     @default("{}")
  detentionJson        Json     @default("{}")
  penaltiesJson        Json     @default("{}")
  approvalTimelineJson Json     @default("[]")
  auditTrailJson       Json     @default("[]")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("vendor_bills")
}

model CustomerInvoice {
  id                String   @id @default(uuid())
  invoiceNumber     String   @unique
  customer          String
  tripsJson         Json     @default("[]")
  invoiceAmount     Float    @default(0)
  gst               Float    @default(0)
  invoiceDate       DateTime @default(now())
  status            String   @default("Draft") // Draft, Approved, Released, Cancelled
  paymentStatus     String   @default("Unpaid") // Unpaid, Partial, Paid, Disputed
  podTriggerJson    Json     @default("{}")
  annexureJson      Json     @default("{}")
  disputedLinesJson Json     @default("[]")
  gstFieldsJson     Json     @default("{}")
  auditTrailJson    Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("customer_invoices")
}

model PaymentRun {
  id                   String   @id @default(uuid())
  batchNumber          String   @unique
  vendor               String
  amount               Float    @default(0)
  paymentMode          String   @default("Bank Transfer") // Bank Transfer, UPI Batch, FASTag, Fuel Card
  approval             String   @default("Pending Maker") // Pending Maker, Pending Checker, Approved, Released, Rejected
  status               String   @default("Queued") // Queued, Processing, Released, Failed
  releaseDate          DateTime @default(now())
  billsIncludedJson    Json     @default("[]")
  bankStatusJson       Json     @default("{}")
  paymentQueueJson     Json     @default("{}")
  makerCheckerJson     Json     @default("{}")
  upiBatchJson         Json     @default("{}")
  vendorPaymentsJson   Json     @default("[]")
  fastagLedgerJson     Json     @default("{}")
  fuelCardLedgerJson   Json     @default("{}")
  approvalTimelineJson Json     @default("[]")
  releaseStatusJson    Json     @default("{}")
  auditTrailJson       Json     @default("[]")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("payment_runs")
}

model DriverSettlement {
  id                      String   @id @default(uuid())
  driverName              String
  driverId                String?
  tripId                  String
  advance                 Float    @default(0)
  expense                 Float    @default(0)
  bhatta                  Float    @default(0)
  recovery                Float    @default(0)
  incentive               Float    @default(0)
  settlement              Float    @default(0)
  status                  String   @default("Draft") // Draft, Approved, Disputed, Paid
  settlementDraftJson     Json     @default("{}")
  disputeStatusJson       Json     @default("{}")
  payrollExportStatusJson Json     @default("{}")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("driver_settlements")
}

model FinancialApproval {
  id                   String   @id @default(uuid())
  approvalNumber       String   @unique
  flowCode             String // AF-07, AF-11
  flowName             String // Vendor Bill Approval, Budget Exception
  entityType           String // Vendor Bill, Budget
  entityId             String
  entityRef            String
  amount               Float    @default(0)
  requestedBy          String
  approver             String?
  status               String   @default("Pending") // Pending, Approved, Rejected
  reason               String?
  budgetCommitmentJson Json     @default("{}")
  timelineJson         Json     @default("[]")
  historyJson          Json     @default("[]")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("financial_approvals")
}

model ErpExport {
  id          String   @id @default(uuid())
  exportNumber String   @unique
  entityType  String // General Ledger, AP Invoices, AR Invoices, Driver Payroll
  format      String // SAP, Oracle, Tally, Excel, CSV, PDF
  recordCount Int      @default(0)
  amountTotal Float    @default(0)
  status      String   @default("Completed") // Completed, Failed, In Progress
  exportedBy  String
  historyJson Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("erp_exports")
}
